PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>

SELECT DISTINCT ?id ?value ?type WHERE {
  # Get additional information
  {
    VALUES ?id { {IDS} }
    ?id rdfs:label ?value
    BIND("label" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id skos:altLabel ?value
    BIND("alias" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id schema:description ?value
    BIND("info" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id wdt:P279/rdfs:label ?supclass
    BIND(CONCAT("is subclass of ", ?supclass) AS ?value)
    BIND("info" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id wdt:P31/rdfs:label ?inst
    BIND(CONCAT("is instance of ", ?inst) AS ?value)
    BIND("info" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id wdt:P106/rdfs:label ?job
    BIND(CONCAT("has occupation ", ?job) AS ?value)
    BIND("info" AS ?type)
  }

  FILTER(LANG(?value) = "en") || LANG(?value) = "")
}
ORDER BY ?id ?type ?value
